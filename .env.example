# Supabase (required for tests and local app)
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=your-anon-key

# Test user credentials (match docs/SUPABASE_SETUP.md)
ADMIN_EMAIL=admin@clinic.test
ADMIN_PASSWORD=your-admin-password
STAFF_EMAIL=staff@clinic.test
STAFF_PASSWORD=your-staff-password

# Optional — override Playwright base URL (default: http://127.0.0.1:4173)
# PORT=4173
# BASE_URL=http://127.0.0.1:4173
