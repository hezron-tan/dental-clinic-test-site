# Supabase (required for tests and local app)
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=your-anon-key

# Direct Postgres access (dashboard / CLI only — not used by the static site)
SUPABASE_DB_PASSWORD=your-database-password

# Test user credentials (match docs/SUPABASE_SETUP.md)
ADMIN_EMAIL=admin@clinic.test
ADMIN_PASSWORD=admin123
STAFF_EMAIL=staff@clinic.test
STAFF_PASSWORD=staff123

# Optional — override Playwright base URL (default: http://127.0.0.1:4173)
# PORT=4173
# BASE_URL=http://127.0.0.1:4173
