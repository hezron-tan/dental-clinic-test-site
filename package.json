{
  "name": "dental-clinic-test-site",
  "private": true,
  "description": "Practice site for Playwright UI/API and K6 performance testing",
  "scripts": {
    "config": "node scripts/generate-config.mjs",
    "verify:supabase": "node scripts/verify-supabase.mjs",
    "build:site": "node scripts/generate-config.mjs && node scripts/prepare-dist.mjs",
    "serve": "node scripts/static-server.mjs",
    "test": "playwright test",
    "test:ui": "playwright test tests/ui",
    "test:api": "playwright test tests/api",
    "test:headed": "playwright test --headed",
    "test:report": "playwright show-report",
    "test:allure": "playwright test",
    "allure:generate": "allure generate allure-results --clean -o allure-report",
    "allure:open": "allure open allure-report",
    "allure:serve": "allure serve allure-results"
  },
  "devDependencies": {
    "@faker-js/faker": "^10.5.0",
    "@playwright/test": "^1.52.0",
    "allure-commandline": "^2.43.0",
    "allure-playwright": "^3.10.2",
    "dotenv": "^16.5.0"
  }
}
